// Schéma PostgreSQL pour la production / Docker
// Usage : npx prisma migrate deploy --schema=prisma/schema.postgresql.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Prisma 7 : URL configurée dans prisma.config.ts (adapter-based)
  provider = "postgresql"
}

enum Role {
  ADMIN
  TECH
}

enum EquipStatus {
  ACTIVE
  INACTIVE
  REPAIR
  DECOMMISSIONED
}

enum IntStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum OrderStatus {
  PENDING
  ORDERED
  PARTIAL
  RECEIVED
  CANCELLED
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  contactEmail  String?
  name          String
  passwordHash  String?
  role          Role           @default(TECH)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  passkeys             Passkey[]
  interventions        Intervention[]
  orders               Order[]
  refreshTokens        RefreshToken[]
  agentTokens          AgentToken[]
  loginLogs            LoginLog[]
  orderAttachments     OrderAttachment[]
  signatureRequests    SignatureRequest[]

  @@map("users")
}

model AgentToken {
  id          String    @id @default(uuid())
  token       String    @unique @default(uuid())
  label       String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  createdById String
  ipWhitelist String?   // JSON array d'IP/CIDR. null = tout autoriser
  ipBlacklist String?   // JSON array d'IP/CIDR. null = rien bloquer

  createdBy        User        @relation(fields: [createdById], references: [id])
  enrolledMachines Equipment[]

  @@map("agent_tokens")
}

model Passkey {
  id             String    @id @default(uuid())
  userId         String
  credentialId   String    @unique
  publicKey      Bytes
  counter        BigInt    @default(0)
  deviceType     String?
  backedUp       Boolean   @default(false)
  transports     String[]
  name           String?
  createdAt      DateTime  @default(now())
  lastUsedAt     DateTime?

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("passkeys")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Room {
  id          String   @id @default(uuid())
  name        String
  building    String?
  floor       Int?
  number      String?
  description String?
  qrToken     String   @unique @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  equipment     Equipment[]
  interventions Intervention[]

  @@map("rooms")
}

model Equipment {
  id              String      @id @default(uuid())
  name            String
  type            String
  brand           String?
  model           String?
  serialNumber    String?     @unique
  status          EquipStatus @default(ACTIVE)
  description     String?
  purchaseDate    DateTime?
  warrantyEnd     DateTime?
  qrToken         String      @unique @default(uuid())
  roomId          String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Champs agent
  discoverySource    String    @default("MANUAL")
  discoveryStatus    String    @default("CONFIRMED")
  suggestedRoomId    String?
  lastSeenAt         DateTime?
  agentInfo          String?
  agentHostname      String?
  agentToken         String?   @unique
  agentRevoked       Boolean   @default(false)     // Si true, re-enrollment requis
  enrollmentTokenId  String?                       // Token de déploiement utilisé à l'enrollment

  room            Room?       @relation(fields: [roomId], references: [id], onDelete: SetNull)
  interventions   Intervention[]
  enrollmentToken AgentToken? @relation(fields: [enrollmentTokenId], references: [id], onDelete: SetNull)
  sessionLogs     MachineSessionLog[]

  @@map("equipment")
}

model Intervention {
  id          String    @id @default(uuid())
  title       String
  description String?
  notes       String?
  status      IntStatus @default(OPEN)
  priority    String    @default("NORMAL")
  photos      String[]
  resolution  String?
  roomId      String?
  equipmentId String?
  techId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  closedAt    DateTime?
  mergedIntoId String?

  room      Room?      @relation(fields: [roomId], references: [id], onDelete: SetNull)
  equipment Equipment? @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  tech      User       @relation(fields: [techId], references: [id])
  mergedInto     Intervention? @relation("MergedInterventions", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedChildren Intervention[] @relation("MergedInterventions")
  orders    Order[]
  reporters InterventionReporter[]

  @@map("interventions")
}

model InterventionReporter {
  id             String       @id @default(uuid())
  interventionId String
  name           String?
  email          String?
  token          String       @unique @default(uuid())
  isPrimary      Boolean      @default(false)
  createdAt      DateTime     @default(now())

  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)

  @@index([interventionId])
  @@index([email])
  @@map("intervention_reporters")
}

model LoginLog {
  id        String   @id @default(uuid())
  userId    String
  method    String   // PASSWORD | PASSKEY
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("login_logs")
}

model Order {
  id             String      @id @default(uuid())
  title          String
  description    String?
  status         OrderStatus @default(PENDING)
  supplier       String?
  totalAmount    Decimal?    @db.Decimal(10, 2)
  deploymentTags String[]    @default([])
  requestedBy    String
  interventionId String?
  orderedAt      DateTime?
  expectedDeliveryAt DateTime?
  receivedAt     DateTime?
  trackingNotes  String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  requester          User               @relation(fields: [requestedBy], references: [id])
  intervention       Intervention?      @relation(fields: [interventionId], references: [id], onDelete: SetNull)
  items              OrderItem[]
  attachments        OrderAttachment[]
  signatureRequests  SignatureRequest[]

  @@index([interventionId])
  @@map("orders")
}

model MachineSessionLog {
  id          String   @id @default(uuid())
  equipmentId String
  winUser     String
  event       String   // LOGIN | LOGOUT
  occurredAt  DateTime

  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@index([occurredAt])
  @@map("machine_session_logs")
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  name        String
  quantity    Int
  unitPrice   Decimal? @db.Decimal(10, 2)
  priceType   String   @default("TTC")
  reference   String?
  productUrl  String?
  received    Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model OrderAttachment {
  id         String   @id @default(uuid())
  orderId    String
  filename   String
  storedAs   String
  mimetype   String
  size       Int
  category   String   @default("OTHER")
  uploadedBy String

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  uploader   User     @relation(fields: [uploadedBy], references: [id])

  createdAt  DateTime @default(now())
  ocrText    String?                        // texte extrait par OCR
  ocrStatus  String   @default("PENDING")  // PENDING | PROCESSING | DONE | FAILED | SKIPPED

  @@map("order_attachments")
}

model SignatureRequest {
  id             String    @id @default(uuid())
  orderId        String?   // null = document générique (non lié à une commande)
  token          String    @unique
  signatureId    String?   @unique

  // Document source (quand orderId est null)
  documentTitle      String?
  documentNotes      String?
  sourceFileStoredAs String?   // fichier dans uploads/signatures/source/
  sourceFilename     String?
  sourceFileMimetype String?

  recipientEmail String
  recipientName  String
  message        String?
  status         String    @default("PENDING")  // PENDING | SIGNED | EXPIRED | CANCELLED
  otpHash        String?
  otpExpiresAt   DateTime?
  otpAttempts    Int       @default(0)
  signedAt       DateTime?
  ipAddress      String?
  userAgent      String?
  attachmentId   String?            // OrderAttachment ID (si commande)
  signedFileStoredAs String?         // PDF signé standalone dans uploads/signatures/signed/
  signedFilename     String?
  signerTitle        String?
  signerPlace        String?
  posX               Float?    // Position X (0-1) de la zone de signature, définie par le demandeur
  posY               Float?    // Position Y (0-1) de la zone de signature, définie par le demandeur
  sigWidth           Float?    // Largeur (0-1) de la zone de signature
  sigHeight          Float?    // Hauteur (0-1) de la zone de signature

  expiresAt      DateTime
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  creator User    @relation(fields: [createdBy], references: [id])

  @@map("signature_requests")
}
