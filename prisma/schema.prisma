generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Dev local SQLite : DATABASE_URL=file:./prisma/dev.db
  // Production PostgreSQL : utiliser schema.postgresql.prisma
  // Prisma 7 : URL configurée dans prisma.config.ts (adapter-based)
  provider = "sqlite"
}

// SQLite ne supporte ni enum, ni Json, ni tableaux natifs.
// Les enums sont stockés en String (validation côté routes).
// Les tableaux (photos, transports) sont stockés en String (JSON sérialisé).

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  contactEmail  String?
  name          String
  passwordHash  String?
  role          String   @default("TECH")   // ADMIN | TECH
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  passkeys             Passkey[]
  interventions        Intervention[]
  orders               Order[]
  refreshTokens        RefreshToken[]
  agentTokens          AgentToken[]
  loginLogs            LoginLog[]
  orderAttachments     OrderAttachment[]
  signatureRequests    SignatureRequest[]
  stockMovements       StockMovement[]
  createdLoanLinks     LoanMagicLink[]
  createdLoanRequests  LoanReservation[] @relation("LoanCreatedBy")
  approvedLoanRequests LoanReservation[] @relation("LoanApprovedBy")
  internalConversationParticipants InternalConversationParticipant[]
  sentInternalMessages            InternalMessage[] @relation("InternalMessageSender")
  checkedCheckupItems            InterventionCheckupItem[]

  @@map("users")
}

model AgentToken {
  id          String    @id @default(uuid())
  token       String    @unique @default(uuid())
  label       String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  createdById String
  ipWhitelist String?   // JSON array d'IP/CIDR. null = tout autoriser
  ipBlacklist String?   // JSON array d'IP/CIDR. null = rien bloquer

  createdBy        User        @relation(fields: [createdById], references: [id])
  enrolledMachines Equipment[]

  @@map("agent_tokens")
}

model Passkey {
  id           String    @id @default(uuid())
  userId       String
  credentialId String    @unique
  publicKey    Bytes
  counter      BigInt    @default(0)
  deviceType   String?
  backedUp     Boolean   @default(false)
  transports   String    @default("[]")   // JSON array sérialisé
  name         String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("passkeys")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Room {
  id          String   @id @default(uuid())
  name        String
  building    String?
  floor       Int?
  number      String?
  description String?
  qrToken     String   @unique @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  equipment     Equipment[]
  interventions Intervention[]

  @@map("rooms")
}

model Equipment {
  id              String    @id @default(uuid())
  name            String
  type            String
  brand           String?
  model           String?
  serialNumber    String?   @unique
  status          String    @default("ACTIVE")     // ACTIVE | INACTIVE | REPAIR | DECOMMISSIONED
  description     String?
  purchaseDate    DateTime?
  warrantyEnd     DateTime?
  qrToken         String    @unique @default(uuid())
  roomId          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Champs agent
  discoverySource    String    @default("MANUAL")    // MANUAL | AGENT
  discoveryStatus    String    @default("CONFIRMED") // CONFIRMED | PENDING
  suggestedRoomId    String?
  lastSeenAt         DateTime?
  agentInfo          String?   // JSON: { cpu, ram, os, ips, macs, user, peripherals }
  agentAlertState    String?   // JSON: suppressions temporaires des alertes agent (réarmées après retour à la normale)
  agentHostname      String?
  agentToken         String?   @unique               // Token machine unique (UUID)
  agentRevoked       Boolean   @default(false)       // Si true, re-enrollment requis
  enrollmentTokenId  String?                         // Token de déploiement utilisé à l'enrollment
  purchasePrice   Float?
  supplierId      String?

  room            Room?       @relation(fields: [roomId], references: [id], onDelete: SetNull)
  interventions   Intervention[]
  enrollmentToken AgentToken? @relation(fields: [enrollmentTokenId], references: [id], onDelete: SetNull)
  sessionLogs     MachineSessionLog[]
  supplierRef     Supplier?   @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  loanResources   LoanResourceEquipment[]
  checkupItems    InterventionCheckupItem[]

  @@map("equipment")
}

model Intervention {
  id          String   @id @default(uuid())
  title       String
  description String?
  notes       String?
  kind        String   @default("STANDARD") // STANDARD | CHECKUP
  status      String   @default("OPEN")    // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  priority    String   @default("NORMAL")  // LOW | NORMAL | HIGH | CRITICAL
  photos      String   @default("[]")      // JSON array sérialisé
  checkupTemplate String @default("[]")    // JSON array sérialisé des étapes à vérifier
  resolution  String?
  roomId      String?
  equipmentId String?
  techId         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  closedAt       DateTime?
  scheduledStartAt DateTime?
  scheduledEndAt   DateTime?
  dueAt            DateTime?
  source         String   @default("INTERNAL")  // INTERNAL | PUBLIC
  reporterName   String?
  reporterEmail  String?
  reporterToken  String?  @unique
  mergedIntoId   String?
  suggestedRoom      String?
  suggestedEquipment String?

  room           Room?      @relation(fields: [roomId], references: [id], onDelete: SetNull)
  equipment      Equipment? @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  tech           User?      @relation(fields: [techId], references: [id])
  mergedInto     Intervention? @relation("MergedInterventions", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedChildren Intervention[] @relation("MergedInterventions")
  orders         Order[]
  stockMovements StockMovement[]
  messages       TicketMessage[]
  reporters      InterventionReporter[]
  checkupItems   InterventionCheckupItem[]
  todos          Todo[]

  @@map("interventions")
}

model Todo {
  id             String        @id @default(uuid())
  interventionId String?
  title          String
  description    String?
  dueAt          DateTime?
  done           Boolean       @default(false)
  doneAt         DateTime?
  createdAt      DateTime      @default(now())

  intervention   Intervention? @relation(fields: [interventionId], references: [id], onDelete: SetNull)

  @@index([interventionId])
  @@map("todos")
}

model InterventionCheckupItem {
  id             String       @id @default(uuid())
  interventionId String
  equipmentId    String
  status         String       @default("PENDING") // PENDING | IN_PROGRESS | DONE
  checklistState String       @default("[]")      // JSON array sérialisé
  notes          String?
  checkedAt      DateTime?
  checkedById    String?
  orderIndex     Int          @default(0)

  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  equipment      Equipment    @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  checkedBy      User?        @relation(fields: [checkedById], references: [id], onDelete: SetNull)

  @@unique([interventionId, equipmentId])
  @@index([interventionId, status, orderIndex])
  @@index([equipmentId])
  @@map("intervention_checkup_items")
}

model InterventionReporter {
  id             String       @id @default(uuid())
  interventionId String
  name           String?
  email          String?
  token          String       @unique @default(uuid())
  isPrimary      Boolean      @default(false)
  createdAt      DateTime     @default(now())

  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)

  @@index([interventionId])
  @@index([email])
  @@map("intervention_reporters")
}

model TicketMessage {
  id             String       @id @default(uuid())
  interventionId String
  content        String       @default("")
  authorType     String       // TECH | REPORTER
  authorName     String?
  attachmentPath String?      // chemin relatif sous uploads/
  attachmentName String?      // nom original du fichier
  attachmentMime String?
  attachmentSize Int?
  readAt         DateTime?    // null = non lu, valeur = horodatage de lecture
  createdAt      DateTime     @default(now())

  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)

  @@map("ticket_messages")
}

model InternalConversation {
  id         String   @id @default(uuid())
  type       String   @default("DIRECT")
  directKey  String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  participants InternalConversationParticipant[]
  messages     InternalMessage[]

  @@map("internal_conversations")
}

model InternalConversationParticipant {
  id             String    @id @default(uuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  archivedAt     DateTime?
  joinedAt       DateTime  @default(now())

  conversation   InternalConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, lastReadAt])
  @@map("internal_conversation_participants")
}

model InternalMessage {
  id             String    @id @default(uuid())
  conversationId String
  senderId       String
  content        String    @default("")
  attachmentPath String?
  attachmentName String?
  attachmentMime String?
  attachmentSize Int?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())

  conversation   InternalConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User                 @relation("InternalMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("internal_messages")
}

model ReporterMagicLink {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique @default(uuid())
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("reporter_magic_links")
}

model Order {
  id             String   @id @default(uuid())
  title          String
  description    String?
  status         String   @default("PENDING")  // PENDING | ORDERED | PARTIAL | RECEIVED | CANCELLED
  supplier       String?
  totalAmount    Float?
  deploymentTags String   @default("[]")       // JSON array of strings
  requestedBy    String
  interventionId String?
  supplierId     String?
  orderedAt      DateTime?
  expectedDeliveryAt DateTime?
  receivedAt     DateTime?
  trackingNotes  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  requester          User               @relation(fields: [requestedBy], references: [id])
  intervention       Intervention?      @relation(fields: [interventionId], references: [id], onDelete: SetNull)
  supplierRef        Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items              OrderItem[]
  attachments        OrderAttachment[]
  signatureRequests  SignatureRequest[]

  @@index([interventionId])
  @@map("orders")
}

model LoginLog {
  id        String   @id @default(uuid())
  userId    String
  method    String   // PASSWORD | PASSKEY
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("login_logs")
}

model MachineSessionLog {
  id          String   @id @default(uuid())
  equipmentId String
  winUser     String   // Nom d'utilisateur Windows
  event       String   // LOGIN | LOGOUT
  occurredAt  DateTime

  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@index([occurredAt])
  @@map("machine_session_logs")
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  name      String
  quantity  Int
  unitPrice Float?
  priceType String   @default("TTC") // TTC | HT
  reference String?
  productUrl String?
  received  Int      @default(0)
  notes     String?
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model OrderAttachment {
  id         String   @id @default(uuid())
  orderId    String
  filename   String
  storedAs   String
  mimetype   String
  size       Int
  category   String   @default("OTHER")  // INVOICE | SIGNED_PO | QUOTE_TO_SIGN | SIGNED_QUOTE | TO_ENTER | OTHER
  uploadedBy String

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  uploader   User     @relation(fields: [uploadedBy], references: [id])

  createdAt  DateTime @default(now())
  ocrText    String?                        // texte extrait par OCR
  ocrStatus  String   @default("PENDING")  // PENDING | PROCESSING | DONE | FAILED | SKIPPED

  @@map("order_attachments")
}

model SignatureRequest {
  id             String    @id @default(uuid())
  orderId        String?   // null = document générique (non lié à une commande)
  token          String    @unique
  signatureId    String?   @unique   // SIG-YYYY-XXXXXXXX (après signature)

  // Document source (quand orderId est null)
  documentTitle      String?
  documentNotes      String?
  sourceFileStoredAs String?   // fichier dans uploads/signatures/source/
  sourceFilename     String?
  sourceFileMimetype String?

  recipientEmail String
  recipientName  String
  message        String?
  status         String    @default("PENDING")  // PENDING | SIGNED | EXPIRED | CANCELLED
  otpHash        String?
  otpExpiresAt   DateTime?
  otpAttempts    Int       @default(0)
  signedAt       DateTime?
  ipAddress      String?
  userAgent      String?
  attachmentId   String?            // OrderAttachment ID (si commande)
  signedFileStoredAs String?         // PDF signé standalone dans uploads/signatures/signed/
  signedFilename     String?
  signerTitle        String?
  signerPlace        String?
  posX               Float?    // Position X (0-1) de la zone de signature, définie par le demandeur
  posY               Float?    // Position Y (0-1) de la zone de signature, définie par le demandeur
  sigWidth           Float?    // Largeur (0-1) de la zone de signature
  sigHeight          Float?    // Hauteur (0-1) de la zone de signature

  expiresAt      DateTime
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  creator User    @relation(fields: [createdBy], references: [id])

  @@map("signature_requests")
}

model Supplier {
  id        String   @id @default(uuid())
  name      String
  contact   String?
  email     String?
  phone     String?
  website   String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders     Order[]
  stockItems StockItem[]
  equipment  Equipment[]

  @@map("suppliers")
}

model StockItem {
  id          String   @id @default(uuid())
  name        String
  reference   String?
  barcode     String?  @unique
  category    String?
  description String?
  quantity    Int      @default(0)
  minQuantity Int      @default(0)
  unitCost    Float?
  location    String?
  supplierId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  supplier    Supplier?        @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  movements   StockMovement[]
  qrCodes     StockQRCodeItem[]

  @@map("stock_items")
}

model StockQRCode {
  id          String   @id @default(uuid())
  token       String   @unique @default(uuid())
  label       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       StockQRCodeItem[]

  @@map("stock_qrcodes")
}

model StockQRCodeItem {
  qrCodeId    String
  stockItemId String

  qrCode      StockQRCode @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  stockItem   StockItem   @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@id([qrCodeId, stockItemId])
  @@map("stock_qrcode_items")
}

model StockMovement {
  id             String   @id @default(uuid())
  stockItemId    String
  type           String                // IN | OUT | ADJUSTMENT
  quantity       Int
  reason         String?
  interventionId String?
  userId         String
  createdAt      DateTime @default(now())

  stockItem    StockItem     @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  intervention Intervention? @relation(fields: [interventionId], references: [id], onDelete: SetNull)
  user         User          @relation(fields: [userId], references: [id])

  @@index([stockItemId])
  @@index([createdAt])
  @@map("stock_movements")
}

model LoanResource {
  id           String   @id @default(uuid())
  name         String
  category     String?
  description  String?
  totalUnits   Int      @default(1)
  bundleSize   Int      @default(1)
  location     String?
  instructions String?
  color        String?
  isActive     Boolean  @default(true)
  usesBundles  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reservations LoanReservation[]
  magicLinks   LoanMagicLink[]
  equipments   LoanResourceEquipment[]

  @@map("loan_resources")
}

model LoanResourceEquipment {
  loanResourceId String
  equipmentId    String
  lotNumber      Int    @default(1)

  loanResource LoanResource @relation(fields: [loanResourceId], references: [id], onDelete: Cascade)
  equipment    Equipment    @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@id([loanResourceId, equipmentId])
  @@map("loan_resource_equipments")
}

model LoanMagicLink {
  id          String    @id @default(uuid())
  token       String    @unique @default(uuid())
  title       String?
  resourceId  String?
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdById String
  createdAt   DateTime  @default(now())

  resource    LoanResource?      @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  createdBy   User               @relation(fields: [createdById], references: [id], onDelete: Cascade)
  requests    LoanReservation[]
  accessLinks LoanRequestAccessLink[]

  @@index([resourceId])
  @@map("loan_magic_links")
}

model LoanRequestAccessLink {
  id            String   @id @default(uuid())
  requestLinkId String
  email         String
  requesterName String?
  token         String   @unique @default(uuid())
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  requestLink LoanMagicLink @relation(fields: [requestLinkId], references: [id], onDelete: Cascade)

  @@index([requestLinkId, email])
  @@index([expiresAt])
  @@map("loan_request_access_links")
}

model LoanReservation {
  id                    String    @id @default(uuid())
  resourceId            String
  requestLinkId         String?
  status                String    @default("PENDING") // PENDING | APPROVED | REJECTED | CANCELLED | RETURNED
  requesterName         String
  requesterEmail        String
  requesterPhone        String?
  requesterOrganization String?
  startAt               DateTime
  endAt                 DateTime
  requestedUnits        Int
  reservedSlots         Int
  additionalNeeds       String?
  notes                 String?
  internalNotes         String?
  createdById           String?
  approvedById          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  resource    LoanResource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  requestLink LoanMagicLink? @relation(fields: [requestLinkId], references: [id], onDelete: SetNull)
  createdBy   User?         @relation("LoanCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy  User?         @relation("LoanApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([resourceId, startAt, endAt])
  @@index([status])
  @@map("loan_reservations")
}
