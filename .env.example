# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Base de données PostgreSQL
DATABASE_URL=postgresql://maintenance_user:maintenance_pass@localhost:5432/maintenance_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Session (pour WebAuthn challenges)
SESSION_SECRET=your-super-secret-session-key-change-in-production
SESSION_MAX_AGE=86400000

# WebAuthn / Passkeys
WEBAUTHN_RP_NAME=MaintenanceBoard
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# Upload fichiers
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Email (optionnel - reset password)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@maintenance.local

# PostgreSQL (pour Docker)
POSTGRES_DB=maintenance_db
POSTGRES_USER=maintenance_user
POSTGRES_PASSWORD=maintenance_pass
