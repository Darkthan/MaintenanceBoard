# Application
NODE_ENV=production
PORT=3000
APP_URL=http://localhost:3000

# Base de données PostgreSQL
DATABASE_URL=postgresql://maintenance_user:maintenance_pass@db:5432/maintenance_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Session (pour WebAuthn challenges)
SESSION_SECRET=your-super-secret-session-key-change-in-production
SESSION_MAX_AGE=86400000

# WebAuthn / Passkeys
WEBAUTHN_RP_NAME=MaintenanceBoard
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# Upload fichiers
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Email (optionnel - reset password)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@maintenance.local

# PostgreSQL (pour Docker)
POSTGRES_DB=maintenance_db
POSTGRES_USER=maintenance_user
POSTGRES_PASSWORD=maintenance_pass

# Seed — comptes initiaux (node prisma/seed.js)
# Remplacez ces valeurs avant le premier démarrage en production
SEED_ADMIN_EMAIL=admin@maintenance.local
SEED_ADMIN_PASSWORD=ChangeMe!Admin123
SEED_ADMIN_NAME=Administrateur
SEED_TECH_EMAIL=tech@maintenance.local
SEED_TECH_PASSWORD=ChangeMe!Tech123
SEED_TECH_NAME=Technicien
# Mettre à false pour ne créer que les comptes (sans données de démo)
SEED_DEMO_DATA=true

# Agent PC — enrollment tokens
# Durée de validité max des tokens d'enrollment (ms, 0 = illimité)
AGENT_ENROLLMENT_MAX_AGE=0
